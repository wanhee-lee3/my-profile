<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Lumio — Light Up Your World</title>
  <link rel="stylesheet" href="css/style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="logo">Lumio<span class="dot">.</span></div>
    <ul class="nav-links">
      <li><a href="#features">Features</a></li>
      <li><a href="#how">How it works</a></li>
      <li><a href="#signup">Join beta</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <span class="badge">✦ Now in Beta</span>
      <h1>Light that<br/><em>thinks</em> with you.</h1>
      <p class="hero-sub">Lumio is the AI-powered lighting system that adapts to your mood, routine, and environment — automatically.</p>
      <a href="#signup" class="btn-primary">Get Early Access →</a>
    </div>
    <div class="hero-visual">
      <div class="orb orb1"></div>
      <div class="orb orb2"></div>
      <div class="orb orb3"></div>
      <div class="lamp-icon">💡</div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features" id="features">
    <h2 class="section-title">Why Lumio?</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🧠</div>
        <h3>AI-Driven Moods</h3>
        <p>Our algorithm learns your daily rhythm and adapts the lighting in real time — no manual control needed.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🌙</div>
        <h3>Sleep Optimized</h3>
        <p>Gradual warm-to-dim transitions prepare your body for rest. Wake up gently with a sunrise simulation.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">⚡</div>
        <h3>Energy Efficient</h3>
        <p>Lumio reduces wasted electricity by up to 40% by only using the light you actually need.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📱</div>
        <h3>One App, Every Room</h3>
        <p>Control every bulb in your home from a single beautifully designed mobile interface.</p>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how" id="how">
    <h2 class="section-title">How it works</h2>
    <div class="steps">
      <div class="step">
        <div class="step-number">01</div>
        <h3>Install in minutes</h3>
        <p>Compatible with any standard socket. No electrician needed.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step">
        <div class="step-number">02</div>
        <h3>Let AI learn</h3>
        <p>Lumio observes your habits over the first week silently.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step">
        <div class="step-number">03</div>
        <h3>Enjoy perfect light</h3>
        <p>Sit back. Your home knows exactly what you need.</p>
      </div>
    </div>
  </section>

  <!-- TYPEFORM EMBED -->
  <section class="signup" id="signup">
    <h2 class="section-title">Join the waitlist</h2>
    <p class="signup-sub">Be the first to experience Lumio. Limited beta spots available.</p>
    <div class="typeform-wrapper">
      <!-- Replace the src with YOUR Typeform embed URL -->
      <iframe
        id="typeform-full"
        width="100%"
        height="500px"
        frameborder="0"
        allow="camera; microphone; autoplay; encrypted-media;"
        src="https://form.typeform.com/to/YOUR_TYPEFORM_ID">
      </iframe>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-logo">Lumio<span class="dot">.</span></div>
    <p>© 2025 Lumio Inc. All rights reserved.</p>
    <p class="footer-tagline">Made with ☀️ and good taste.</p>
  </footer>

</body>
</html>